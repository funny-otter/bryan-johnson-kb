---
type SectionKey = 'habits' | 'longterm' | 'donts';
type ProtocolItem = { text: string; source: string };
type Protocol = {
  category: string;
  title: string;
  lede: string;
  confidence: string;
  sourcePaths: string[];
  sections: Partial<Record<SectionKey, ProtocolItem[]>>;
  cards: Array<{ label: string; title: string; body: string }>;
};

const { protocol, caution = 'Source-aware summary only; not medical advice. Exact interventions require source verification and clinician guidance.' } = Astro.props as {
  protocol: Protocol;
  caution?: string;
};

const sourcedItems = (key: SectionKey, fallback: string) => {
  const items = Array.isArray(protocol.sections?.[key]) ? protocol.sections[key] ?? [] : [];
  const rows = items.length ? items : [{ text: fallback, source: 'source pending' }];
  return rows.map((item, index) => ({
    ...item,
    index: index + 1,
  }));
};

const habitRows = sourcedItems('habits', 'No source-backed daily habits are published for this protocol yet.').map((item) => ({
  ...item,
  time: item.text.match(/sleep|bedtime|wake/i) ? 'night' : item.text.match(/meal|breakfast|dinner|calorie|food|protein|nutrition/i) ? 'meal' : 'daily',
}));

const objectiveRows = sourcedItems('longterm', 'No source-backed long-term objectives are published for this protocol yet.').map((item) => {
  const [rawTarget, ...rest] = item.text.split(/—|:|;/);
  const target = rawTarget && rawTarget.length <= 34 ? rawTarget.trim() : `target ${String(item.index).padStart(2, '0')}`;
  return {
    ...item,
    target,
    text: rest.length ? rest.join('—').trim() : item.text,
  };
});

const forbiddenRows = sourcedItems('donts', 'No source-backed forbidden items are published for this protocol yet.');
const sourcePreview = protocol.sourcePaths.slice(0, 5);
const confidenceMix = [
  { label: 'source-backed', value: protocol.confidence === 'medium' ? 62 : 48 },
  { label: 'claim-framed', value: protocol.confidence === 'mixed' ? 39 : 25 },
  { label: 'guardrail', value: 21 },
];
---

<section class="protocol-page protocol-dossier" aria-labelledby="protocol-title">
  <div class="watch-head protocol-command">
    <div>
      <p class="eyebrow">// PROTOCOLS / {protocol.category}</p>
      <h1 id="protocol-title"><span>▶</span> {protocol.title}</h1>
      <p>{protocol.lede}</p>
    </div>
    <div class="watch-actions protocol-filter-row" aria-label="Protocol section shortcuts">
      <a class="watch-chip active" href={`/${protocol.category}/`}># all</a>
      <a class="watch-chip" href={`/${protocol.category}/#habits`}># habits</a>
      <a class="watch-chip" href={`/${protocol.category}/#longterm`}># objectives</a>
      <a class="watch-chip" href={`/${protocol.category}/#donts`}># forbidden</a>
    </div>
  </div>

  <div class="protocol-dossier-grid">
    <div class="protocol-primary" aria-label={`${protocol.title} habits and objectives`}>
      <p class="lead">Daily inputs, long-range targets, and explicit avoidances are separated into the same terminal panels as the BJ.WATCH reference. <em>Source-aware summary only.</em></p>

      <div class="habit-list" id="habits" role="table" aria-label={`${protocol.title} daily habits`}>
        <div class="habit-head" role="row">
          <span>idx</span><span>time</span><span>habit</span>
        </div>
        {habitRows.map((row) => (
          <div class="habit" role="row" data-source={row.source}>
            <span class="id" role="cell">{String(row.index).padStart(2, '0')}</span>
            <span class="h-time" role="cell">{row.time}<span class="h-dose-inline">HBT</span></span>
            <span class="h-copy" role="cell">
              <strong class="h-title">{row.text}</strong>
              <span class="h-why"><code>{row.source}</code></span>
            </span>
          </div>
        ))}
      </div>

      <div class="two">
        <div class="panel objectives-panel" id="longterm">
          <h3>Long-term objectives</h3>
          {objectiveRows.map((row) => (
            <div class="obj" data-source={row.source}>
              <span class="target">{row.target}</span>
              <span class="text"><strong>{row.text}</strong><small>{row.source}</small></span>
            </div>
          ))}
        </div>
        <div class="panel forbidden-panel" id="donts">
          <h3>Forbidden</h3>
          {forbiddenRows.map((row) => (
            <div class="dont" data-source={row.source}>
              <span class="sr-only">FORBID: </span>
              <span class="dont-copy"><span>{row.text}</span><small>{row.source}</small></span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <aside class="protocol-dossier-side" aria-label="Protocol analysis panels">
      <section class="protocol-analysis-panel">
        <h2>// SOURCE TRAILS</h2>
        <ul class="compact-list">
          {sourcePreview.map((path) => (
            <li><code>{path}</code><small>linked wiki/source trail</small></li>
          ))}
        </ul>
      </section>

      <section class="protocol-analysis-panel">
        <h2>// CONFIDENCE MIX</h2>
        <div class="mix-list">
          {confidenceMix.map((item) => (
            <div class="mix-row">
              <div><span>{item.label}</span><strong>{item.value}%</strong></div>
              <meter min="0" max="100" value={item.value}>{item.value}%</meter>
            </div>
          ))}
        </div>
      </section>

      <section class="protocol-analysis-panel protocol-caution-panel">
        <h2>// GUARDRAILS</h2>
        <p>{caution}</p>
      </section>

      <section class="protocol-analysis-panel">
        <h2>// RELATED CONCEPTS</h2>
        <ul class="compact-list">
          {protocol.cards.map((card) => (
            <li><a href={`/concepts/`}>{card.title}</a><small>{card.label}</small></li>
          ))}
        </ul>
      </section>
    </aside>
  </div>
</section>
