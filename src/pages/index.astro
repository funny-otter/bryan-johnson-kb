---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { coreTopicSlugs, curatedRecentNews } from '../data/curated-home.mjs';

const entries = (await getCollection('knowledge')).sort((a, b) => (b.data.updated || '').localeCompare(a.data.updated || ''));
const entryBySlug = new Map(entries.map((entry) => [entry.data.slug, entry]));
const coreTopics = coreTopicSlugs.flatMap((slug) => {
  const entry = entryBySlug.get(slug);
  return entry ? [entry] : [];
});
const updateCards = curatedRecentNews
  .slice()
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''))
  .slice(0, 5);
const dateFormatter = new Intl.DateTimeFormat('en', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const formatDate = (date = '') => {
  if (!date) return 'Undated';
  const parsed = new Date(`${date}T00:00:00Z`);
  return Number.isNaN(parsed.getTime()) ? date : dateFormatter.format(parsed);
};
const sourceLabel = (count = 0) => `${count} source${count === 1 ? '' : 's'}`;
const explorationPaths = [
  {
    href: '/metrics/',
    label: 'Metrics',
    kicker: 'Separate dashboard',
    title: 'Move from headlines to measurement trends',
    body: 'Open the content-metrics view when you want volume and velocity instead of landing-page context.',
  },
  {
    href: '/knowledge/blueprint-protocol/',
    label: 'Protocols',
    kicker: 'Action layer',
    title: 'Read protocol notes with medical caution preserved',
    body: 'See how Blueprint habits, testing, and protocol claims are summarized from the wiki source set.',
  },
  {
    href: '/timeline/',
    label: 'Timeline',
    kicker: 'Sequence',
    title: 'Place recent claims in historical order',
    body: 'Use the chronology when a product launch, public claim, or critique needs date-aware context.',
  },
  {
    href: '/sources/',
    label: 'Sources',
    kicker: 'Receipts',
    title: 'Trace public pages back to source paths',
    body: 'Inspect source notes and related pages instead of treating the dashboard as unsourced advice.',
  },
];
---
<BaseLayout title="Bryan Johnson KB · Overview" description="Fresh activity dashboard for recent Bryan Johnson, Blueprint, Don't Die, and longevity knowledge-base updates.">
  <div class="home-command">
    <section class="activity-hero" aria-labelledby="activity-title">
      <div class="activity-copy">
        <p class="eyebrow">Latest signals</p>
        <h1 id="activity-title">Recent Bryan Johnson updates</h1>
        <p class="activity-lede">The overview starts with current activity. Use deeper sections for protocol notes, timelines, source trails, and metrics.</p>
        <div class="activity-actions" aria-label="Primary actions">
          <a class="command-button primary" href="/changelog/">Open changelog</a>
          <a class="command-button" href="/search/">Search the KB</a>
        </div>
      </div>

      <div class="activity-stack" id="recent-activity" aria-label="Recent activity update cards">
        <div class="stack-header">
          <div>
            <p class="eyebrow">Recent news</p>
            <h2>Activity queue</h2>
          </div>
          <a class="queue-link" href="/changelog/">Changelog</a>
        </div>
        <div class="signal-list">
          {updateCards.map((item, index) => (
            <a class:list={["signal-card", { primary: index === 0 }]} href={item.href}>
              <div class="signal-index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</div>
              <div class="signal-body">
                <div class="card-topline">
                  <span>{item.badge}</span>
                  <time datetime={item.date}>{formatDate(item.date)}</time>
                </div>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
                <div class="signal-meta">
                  <span>{item.topic}</span>
                  <span>{sourceLabel(item.sources.length)}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="overview-sections" aria-label="Overview sections">
      <section class="section-pathways" aria-labelledby="pathways-title">
            <div class="section-head compact-head">
              <div>
                <p class="eyebrow">Next moves</p>
                <h2 id="pathways-title">Choose a deeper view</h2>
              </div>
              <p class="section-note">No duplicate dashboard wall here — each tile is an entry point into the section built for that job.</p>
            </div>

            <div class="pathway-grid">
              {explorationPaths.map((path) => (
                <a class="pathway-card" href={path.href}>
                  <span class="pathway-kicker">{path.kicker}</span>
                  <strong>{path.label}</strong>
                  <h3>{path.title}</h3>
                  <p>{path.body}</p>
                </a>
              ))}
            </div>
      </section>

      <section class="topic-ledger" aria-labelledby="topic-ledger-title">
            <div>
              <p class="eyebrow">Core dossiers</p>
              <h2 id="topic-ledger-title">Pinned knowledge paths</h2>
            </div>
            <div class="topic-list">
              {coreTopics.map((entry) => (
                <a class="topic-row" href={`/knowledge/${entry.data.slug}/`}>
                  <span>{entry.data.type}</span>
                  <strong>{entry.data.title}</strong>
                  <p>{entry.data.summary}</p>
                </a>
              ))}
            </div>
      </section>
    </section>
  </div>
</BaseLayout>
