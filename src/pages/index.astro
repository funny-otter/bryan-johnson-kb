---
import BaseLayout from '../layouts/BaseLayout.astro';
import KnowledgeCard from '../components/KnowledgeCard.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('knowledge')).sort((a, b) => (b.data.updated || '').localeCompare(a.data.updated || ''));
const updates = (await getCollection('updates')).sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''));
const recentNews = entries.slice(0, 3);
const featured = entries.slice(3, 7);
const types = new Map();
for (const entry of entries) types.set(entry.data.type, (types.get(entry.data.type) || 0) + 1);
const latestKnowledgeUpdate = entries.map((e) => e.data.updated).filter(Boolean).sort().at(-1) || 'n/a';
const latestChange = updates[0]?.data.date || latestKnowledgeUpdate;
const dateFormatter = new Intl.DateTimeFormat('en', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const formatDate = (date?: string) => {
  if (!date) return 'Undated';
  const parsed = new Date(`${date}T00:00:00Z`);
  return Number.isNaN(parsed.getTime()) ? date : dateFormatter.format(parsed);
};
const cleanMarkdown = (value = '') => value.replace(/[`*_#[\]()]/g, '').replace(/\s+/g, ' ').trim();
const updateSummary = (body?: string) => {
  const firstBullet = body?.split('\n').find((line) => line.trim().startsWith('- '));
  const summary = cleanMarkdown(firstBullet?.replace(/^\s*-\s*/, '') || body?.split('\n').find((line) => line.trim() && !line.startsWith('#')) || 'Recently published wiki maintenance and synthesis work.');
  return summary.length > 185 ? `${summary.slice(0, 182)}…` : summary;
};
---
<BaseLayout title="Bryan Johnson KB · Overview" description="Concise overview of recent Bryan Johnson, Blueprint, Don't Die, and longevity knowledge-base updates.">
  <div class="container home-overview">
    <section class="hero hero-polished">
      <div>
        <p class="pill" style="display:inline-flex">Source-backed longevity intelligence</p>
        <h1>Bryan Johnson knowledge base.</h1>
        <p class="lede">A concise, curated briefing on Bryan Johnson, Blueprint, Don't Die, and measurement-first longevity ideas — synthesized from the local llm-wiki into public, reader-friendly context.</p>
      </div>
      <aside class="panel overview-stats" aria-label="Knowledge base statistics">
        <div class="stat"><span>Published pages</span><strong>{entries.length}</strong></div>
        <div class="stat"><span>Latest change</span><strong>{latestChange}</strong></div>
        <div class="stat"><span>Content types</span><strong>{types.size}</strong></div>
        <a class="stat stat-link" href="/search/"><span>Search index</span><strong>Open</strong></a>
      </aside>
    </section>

    <section class="overview-tabs" aria-label="Overview and changelog tabs">
      <input class="tab-input" type="radio" id="overview-tab-overview" name="overview-home-tabs" checked />
      <input class="tab-input" type="radio" id="overview-tab-changelog" name="overview-home-tabs" />

      <div class="tab-list" role="tablist" aria-label="Home page sections">
        <label role="tab" for="overview-tab-overview">Overview</label>
        <label role="tab" for="overview-tab-changelog">Changelog</label>
      </div>

      <div class="tab-panels">
        <div class="tab-panel" data-tab="overview" role="tabpanel" aria-labelledby="overview-tab-overview">
          <div class="section-head compact-head">
            <div>
              <p class="eyebrow">Current briefing</p>
              <h2>Recent news</h2>
            </div>
            <a class="pill" href="/search/">Search all</a>
          </div>

          {recentNews.length > 0 ? (
            <section class="news-grid" aria-label="Recent knowledge-base news">
              {recentNews.map((entry, index) => (
                <a class:list={["news-card", { featured: index === 0 }]} href={`/knowledge/${entry.data.slug}/`}>
                  <div class="card-topline">
                    <span>{entry.data.type}</span>
                    <time datetime={entry.data.updated}>{formatDate(entry.data.updated)}</time>
                  </div>
                  <h3>{entry.data.title}</h3>
                  <p>{entry.data.summary || 'Compiled wiki page with source-backed notes and cross-references.'}</p>
                  <div class="badges">
                    {(entry.data.tags || []).slice(0, 4).map((tag: string) => <span class="badge">#{tag}</span>)}
                  </div>
                </a>
              ))}
            </section>
          ) : (
            <div class="empty-state">
              <h3>No recent news yet</h3>
              <p>New Bryan Johnson and Blueprint summaries will appear here after the next curated wiki publish.</p>
            </div>
          )}

          <div class="section-head lower-head">
            <div>
              <p class="eyebrow">Explore</p>
              <h2>Core topics</h2>
            </div>
          </div>
          {featured.length > 0 ? (
            <section class="grid compact-grid">
              {featured.map((entry) => <KnowledgeCard entry={entry} />)}
            </section>
          ) : (
            <div class="empty-state subdued"><p>Additional topic cards will appear as the public knowledge base expands.</p></div>
          )}
        </div>

        <div class="tab-panel" data-tab="changelog" role="tabpanel" aria-labelledby="overview-tab-changelog">
          <div class="section-head compact-head">
            <div>
              <p class="eyebrow">Recently updated material</p>
              <h2>Changelog</h2>
            </div>
          </div>

          {updates.length > 0 ? (
            <ol class="changelog-list" aria-label="Recent update history">
              {updates.map((update) => (
                <li class="changelog-item">
                  <time datetime={update.data.date}>{formatDate(update.data.date)}</time>
                  <div>
                    <h3>{update.data.title}</h3>
                    <p>{updateSummary(update.body)}</p>
                    {update.data.wikiPaths.length > 0 && (
                      <div class="source-chips" aria-label="Updated wiki paths">
                        {update.data.wikiPaths.slice(0, 5).map((path: string) => <code>{path}</code>)}
                        {update.data.wikiPaths.length > 5 && <span class="badge">+{update.data.wikiPaths.length - 5} more</span>}
                      </div>
                    )}
                  </div>
                </li>
              ))}
            </ol>
          ) : (
            <div class="empty-state">
              <h3>No changelog entries yet</h3>
              <p>Curated wiki publish notes will appear here when updated material is available.</p>
            </div>
          )}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
