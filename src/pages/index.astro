---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { coreTopicSlugs, curatedRecentNews } from '../data/curated-home.mjs';
import { curatedActivity, curatedSignals, sourceCounts, watchQueue } from '../data/signals.mjs';
import { conceptEntries, protocolCategories } from '../data/protocols.mjs';

const entries = (await getCollection('knowledge')).sort((a, b) => (b.data.updated || '').localeCompare(a.data.updated || ''));
const entryBySlug = new Map(entries.map((entry) => [entry.data.slug, entry]));
const coreTopics = coreTopicSlugs.flatMap((slug) => {
  const entry = entryBySlug.get(slug);
  return entry ? [entry] : [];
});
const curatedNewsArchiveCount = curatedRecentNews.length;
const signalCards = curatedSignals
  .slice()
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''))
  .slice(0, 8);
const dateFormatter = new Intl.DateTimeFormat('en', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const shortDateFormatter = new Intl.DateTimeFormat('en', { month: 'short', day: '2-digit', timeZone: 'UTC' });
const formatDate = (date = '') => {
  if (!date) return 'Undated';
  const parsed = new Date(`${date}T00:00:00Z`);
  return Number.isNaN(parsed.getTime()) ? date : dateFormatter.format(parsed);
};
const formatShortDate = (date = '') => {
  if (!date) return 'n/a';
  const parsed = new Date(`${date}T00:00:00Z`);
  return Number.isNaN(parsed.getTime()) ? date : shortDateFormatter.format(parsed);
};
const sourceLabel = (count = 0) => `${count} source${count === 1 ? '' : 's'}`;
const topicTotals = signalCards.reduce((acc, item) => {
  acc.set(item.topic, (acc.get(item.topic) || 0) + 1);
  return acc;
}, new Map());
const topicMix = Array.from(topicTotals.entries()).map(([topic, count]) => ({
  topic,
  count,
  percent: Math.round((count / Math.max(signalCards.length, 1)) * 100),
}));
const activityMax = Math.max(1, ...curatedActivity.map((item) => item.x_post + item.third_party + item.wiki_update + item.site_update));
const latestDate = signalCards[0]?.date || '';
---
<BaseLayout title="BJ.WATCH · Bryan Johnson KB" description="Terminal-style curated dashboard for recent Bryan Johnson, Blueprint, Don't Die, and longevity knowledge-base updates." section="overview">
  <section class="watch-board" aria-labelledby="watch-title">
    <div class="watch-head">
      <div>
        <h1 id="watch-title"><span aria-hidden="true">▶</span> Latest signal</h1>
        <p>last curated pass {formatDate(latestDate)} · {signalCards.length} public entries · source-aware summaries from {curatedNewsArchiveCount} legacy curated cards plus llm-wiki tweets</p>
      </div>
      <div class="watch-actions" aria-label="Quick filters">
        <a class="watch-chip active" href="/"># all</a>
        <a class="watch-chip" href="/health/"># health</a>
        <a class="watch-chip" href="/longevity/"># longevity</a>
        <a class="watch-chip" href="/nutrition/"># nutrition</a>
        <a class="watch-chip" href="/sleep/"># sleep</a>
        <a class="watch-chip" href="/concepts/"># concepts</a>
      </div>
    </div>

    <div class="watch-grid">
      <section class="signal-terminal" aria-labelledby="signal-table-title">
        <div class="signal-terminal-labels" aria-hidden="true">
          <span>DATE</span>
          <span>TAG</span>
          <span>CONTENT</span>
          <span>SOURCES</span>
        </div>
        <h2 id="signal-table-title" class="sr-only">Recent curated signals</h2>
        <div class="signal-terminal-rows">
          {signalCards.map((item, index) => (
            <a class="signal-terminal-row" href={item.href}>
              <time datetime={item.date}><strong>{formatShortDate(item.date)}</strong><span>{index === 0 ? 'latest' : item.tweetId ? `tweet ${item.tweetId.slice(-4)}` : `${index + 1} rec`}</span></time>
              <span class:list={["signal-tag", `tag-${item.badge.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`]}>{item.badge}</span>
              <span class="signal-copy">
                <strong>{item.title}</strong>
                <span>{item.summary}</span>
              </span>
              <span class="signal-engagement"><strong>{sourceLabel(item.sources.length)}</strong><small>{item.topic}</small></span>
            </a>
          ))}
        </div>
      </section>

      <aside class="watch-side" aria-label="Signal analysis panels">
        <section class="watch-panel topic-mix" aria-labelledby="topic-mix-title">
          <h2 id="topic-mix-title">// Topic mix · curated signals</h2>
          <div class="mix-list">
            {topicMix.map((item) => (
              <div class="mix-row">
                <div><span>{item.topic}</span><strong>{item.percent}%</strong></div>
                <meter min="0" max="100" value={item.percent}>{item.percent}%</meter>
              </div>
            ))}
          </div>
        </section>

        <section class="watch-panel" aria-labelledby="activity-title">
          <h2 id="activity-title">// Activity · curated source activity</h2>
          <div class="activity-bars" aria-label="Curated source activity by date">
            {curatedActivity.map((item) => {
              const total = item.x_post + item.third_party + item.wiki_update + item.site_update;
              return (
                <div class="activity-row">
                  <span>{formatShortDate(item.date)}</span>
                  <meter min="0" max={activityMax} value={total}>{total}</meter>
                  <strong>{total}</strong>
                </div>
              );
            })}
          </div>
          <small>Curated source activity, not full @bryan_johnson posting telemetry.</small>
        </section>

        <section class="watch-panel" aria-labelledby="recent-tweets-title">
          <h2 id="recent-tweets-title">// Recent tweets/signals</h2>
          <ul class="compact-list">
            {signalCards.filter((item) => item.tweetId).slice(0, 5).map((item) => (
              <li><a href={item.href}>{item.title}</a><small>tweet {item.tweetId} · {item.confidence} confidence</small></li>
            ))}
          </ul>
        </section>

        <section class="watch-panel next-watch" aria-labelledby="next-watch-title">
          <h2 id="next-watch-title">// Next watch</h2>
          <ul class="compact-list">
            {watchQueue.slice(0, 3).map((item) => (
              <li><a href={item.href}>{item.title}</a><small>{item.summary}</small></li>
            ))}
          </ul>
        </section>

        <section class="watch-panel" aria-labelledby="source-counts-title">
          <h2 id="source-counts-title">// Source counts</h2>
          <div class="source-count-grid">
            {sourceCounts.map((item) => (
              <div><strong>{item.value}</strong><span>{item.label}</span><small>{item.detail}</small></div>
            ))}
          </div>
          <small>Protocol tabs backed: {protocolCategories.length}; concepts mapped: {conceptEntries.length}.</small>
        </section>
      </aside>
    </div>
  </section>

  <section class="watch-lower" aria-labelledby="paths-title">
    <div class="watch-section-head">
      <p>// Reference paths</p>
      <h2 id="paths-title">Move from feed to dossiers</h2>
      <span>Each route keeps source trails and medical caution visible.</span>
    </div>
    <div class="watch-path-grid">
      <a class="watch-path action" href="/health/">
        <span>Protocol</span>
        <strong>Health</strong>
        <p>Measurement loops, sleep consistency, oral care, exercise, and caution around experimental interventions.</p>
      </a>
      <a class="watch-path action" href="/nutrition/">
        <span>Protocol</span>
        <strong>Nutrition</strong>
        <p>Plant-led food pattern, Blueprint products, microplastics claims, and metabolic-drug caveats.</p>
      </a>
      <a class="watch-path action" href="/sleep/">
        <span>Protocol</span>
        <strong>Sleep</strong>
        <p>Bedtime discipline, front-loading examples, and metric caution from tweet-backed sources.</p>
      </a>
      <a class="watch-path action" href="/concepts/">
        <span>Reference</span>
        <strong>Concepts</strong>
        <p>12 source-aware glossary entries, including concepts without dedicated wiki pages yet.</p>
      </a>
      {coreTopics.map((entry) => (
        <a class="watch-path" href={`/knowledge/${entry.data.slug}/`}>
          <span>{entry.data.type}</span>
          <strong>{entry.data.title}</strong>
          <p>{entry.data.summary}</p>
        </a>
      ))}
      <a class="watch-path action" href="/metrics/">
        <span>Signal</span>
        <strong>Metrics</strong>
        <p>Inspect source velocity by range, content type, and fallback API state.</p>
      </a>
    </div>
  </section>
</BaseLayout>
