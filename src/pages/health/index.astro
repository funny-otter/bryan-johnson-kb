---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProtocolDossier from '../../components/ProtocolDossier.astro';
import { protocolCategories } from '../../data/protocols.mjs';
const protocol = protocolCategories.find((item) => item.category === 'health')!;
---
<BaseLayout title="Health protocol · BJ.WATCH" description="Source-aware Bryan Johnson health protocol notes with medical caution." section="health">
  <ProtocolDossier protocol={protocol} caution="Source-aware summary only; not medical advice. Exact targets and interventions require source verification and clinician guidance." />
</BaseLayout>
