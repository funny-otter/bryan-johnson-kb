---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { opinionItems } from '../../data/dashboard-sections';
const title = 'Opinions';
---
<BaseLayout title={`${title} · Bryan Johnson KB`} description="Claim and stance cards for Bryan Johnson, Blueprint, and Don't Die.">
  <div class="container">
    <section class="section-intro">
      <p class="eyebrow">Claims, stances, caveats</p>
      <div class="section-head"><h2>{title}</h2><span class="pill">{opinionItems.length} claims</span></div>
      <p class="lead">This tab is intentionally not a generic page index. It pulls out Bryan Johnson / Blueprint positions, the evidence angle, and the main caveat so readers can see what is a stance, what is sourced, and what remains contested.</p>
    </section>

    <section class="opinion-list" aria-label="Opinion and claim cards">
      {opinionItems.map((item) => (
        <article class="opinion-card">
          <div class="card-topline">
            <span class={`confidence confidence-${item.confidence}`}>{item.confidence} confidence</span>
            <a href={item.relatedHref}>{item.relatedTitle}</a>
          </div>
          <h3>{item.claim}</h3>
          <dl class="claim-grid">
            <div>
              <dt>Position</dt>
              <dd>{item.position}</dd>
            </div>
            <div>
              <dt>Counterpoint / caution</dt>
              <dd>{item.counterpoint}</dd>
            </div>
          </dl>
          <div class="source-chips" aria-label="Supporting source paths">
            {item.sources.map((source) => <code>{source}</code>)}
          </div>
        </article>
      ))}
    </section>
  </div>
</BaseLayout>
