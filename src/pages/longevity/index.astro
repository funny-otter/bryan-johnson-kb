---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProtocolDossier from '../../components/ProtocolDossier.astro';
import { protocolCategories } from '../../data/protocols.mjs';
const protocol = protocolCategories.find((item) => item.category === 'longevity')!;
---
<BaseLayout title="Longevity protocol · BJ.WATCH" description="Source-aware Bryan Johnson longevity protocol notes with claim framing." section="longevity">
  <ProtocolDossier protocol={protocol} caution="Source-aware summary only; not medical advice. Claims about biological age, enhancement, or immortality remain claims unless independently validated." />
</BaseLayout>
