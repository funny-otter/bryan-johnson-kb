---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { timelineEvents } from '../../data/dashboard-sections';
const title = 'Timeline';
const events = [...timelineEvents].sort((a, b) => a.date.localeCompare(b.date));
---
<BaseLayout title={`${title} · Bryan Johnson KB`} description="Chronological Bryan Johnson, Blueprint, Don't Die, and source-update events.">
  <div class="container">
    <section class="section-intro">
      <p class="eyebrow">Chronology, not update sort</p>
      <div class="section-head"><h2>{title}</h2><span class="pill">{events.length} dated events</span></div>
      <p class="lead">A date-first view of the KB: company milestones, Blueprint/Don’t Die developments, protocol reversals, and source-ingest moments. Events link back to the relevant knowledge page and cite the source path used by the wiki.</p>
    </section>

    <ol class="timeline" aria-label="Chronological events">
      {events.map((event) => (
        <li class="timeline-event">
          <time datetime={event.date}>{event.date}</time>
          <div class="timeline-body">
            <div class="card-topline">
              <span class={`confidence confidence-${event.confidence}`}>{event.confidence} confidence</span>
              <a href={event.relatedHref}>{event.relatedTitle}</a>
            </div>
            <h3>{event.label}</h3>
            <p>{event.summary}</p>
            <code>{event.source}</code>
          </div>
        </li>
      ))}
    </ol>
  </div>
</BaseLayout>
