---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KnowledgePageShell from '../../components/KnowledgePageShell.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('knowledge');
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const frontmatterSummary = entry.data.summary?.trim();
const firstBodyParagraph = entry.body
  ?.split(/\n{2,}/)
  .map((block) =>
    block
      .trim()
      .replace(/\n/g, ' ')
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
      .replace(/[*_`]/g, '')
  )
  .find((block) => block && !block.startsWith('#'));
const description = entry.data.summary ?? `${entry.data.title} in the Bryan Johnson knowledge base.`;
const heroSummary = frontmatterSummary && /[.!?]$/.test(frontmatterSummary) ? frontmatterSummary : firstBodyParagraph ?? frontmatterSummary;
---

<BaseLayout title={`${entry.data.title} · Bryan Johnson KB`} description={description}>
  <KnowledgePageShell entry={entry} summary={heroSummary}>
    <Content />
  </KnowledgePageShell>
</BaseLayout>
