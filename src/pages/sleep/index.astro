---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { protocolCategories } from '../../data/protocols.mjs';
const protocol = protocolCategories.find((item) => item.category === 'sleep')!;
---
<BaseLayout title="Sleep protocol · BJ.WATCH" description="Source-aware Bryan Johnson sleep protocol notes with medical caution." section="sleep">
  <section class="protocol-page" aria-labelledby="protocol-title">
    <p class="eyebrow">// PROTOCOLS / sleep</p>
    <h1 id="protocol-title">{protocol.title}</h1>
    <p class="lede">{protocol.lede}</p>
    <p class="source-aware-note">Source-aware summary only; not medical advice. Sleep score, REM, HRV, and wake-event values stay out until source verified.</p>
    <div class="protocol-grid">
      {protocol.cards.map((card) => (
        <article class="protocol-card">
          <span>{card.label}</span>
          <h2>{card.title}</h2>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
    <section class="source-panel" aria-labelledby="sleep-sources">
      <h2 id="sleep-sources">Source trails</h2>
      <div class="source-chips">{protocol.sourcePaths.map((path) => <code>{path}</code>)}</div>
    </section>
  </section>
</BaseLayout>
