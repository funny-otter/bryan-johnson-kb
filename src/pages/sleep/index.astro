---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProtocolDossier from '../../components/ProtocolDossier.astro';
import { protocolCategories } from '../../data/protocols.mjs';
const protocol = protocolCategories.find((item) => item.category === 'sleep')!;
---
<BaseLayout title="Sleep protocol · BJ.WATCH" description="Source-aware Bryan Johnson sleep protocol notes with medical caution." section="sleep">
  <ProtocolDossier protocol={protocol} caution="Source-aware summary only; not medical advice. Sleep score, REM, HRV, and wake-event values stay out until source verified." />
</BaseLayout>
