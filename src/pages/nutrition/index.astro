---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProtocolSections from '../../components/ProtocolSections.astro';
import { protocolCategories } from '../../data/protocols.mjs';
const protocol = protocolCategories.find((item) => item.category === 'nutrition')!;
---
<BaseLayout title="Nutrition protocol · BJ.WATCH" description="Source-aware Bryan Johnson nutrition protocol notes with medical caution." section="nutrition">
  <section class="protocol-page" aria-labelledby="protocol-title">
    <p class="eyebrow">// PROTOCOLS / nutrition</p>
    <h1 id="protocol-title">{protocol.title}</h1>
    <p class="lede">{protocol.lede}</p>
    <p class="source-aware-note">Source-aware summary only; not medical advice. Prototype calorie, macro, drug, and eating-window numbers are intentionally omitted unless source-backed.</p>
    <ProtocolSections sections={protocol.sections} title={`${protocol.title}: habits, longterm, and don’ts`} />
    <div class="protocol-grid">
      {protocol.cards.map((card) => (
        <article class="protocol-card">
          <span>{card.label}</span>
          <h2>{card.title}</h2>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
    <section class="source-panel" aria-labelledby="nutrition-sources">
      <h2 id="nutrition-sources">Source trails</h2>
      <div class="source-chips">{protocol.sourcePaths.map((path) => <code>{path}</code>)}</div>
    </section>
  </section>
</BaseLayout>
