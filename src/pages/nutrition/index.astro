---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProtocolDossier from '../../components/ProtocolDossier.astro';
import { protocolCategories } from '../../data/protocols.mjs';
const protocol = protocolCategories.find((item) => item.category === 'nutrition')!;
---
<BaseLayout title="Nutrition protocol · BJ.WATCH" description="Source-aware Bryan Johnson nutrition protocol notes with medical caution." section="nutrition">
  <ProtocolDossier protocol={protocol} caution="Source-aware summary only; not medical advice. Prototype calorie, macro, drug, and eating-window numbers are intentionally omitted unless source-backed." />
</BaseLayout>
